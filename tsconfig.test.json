{
  // Tests run under vitest (Node), but import both main (Node) and renderer (DOM)
  // code, so this config intentionally carries BOTH environments. The strict
  // per-environment isolation is enforced by tsconfig.node.json / tsconfig.web.json
  // against the shipped source; this config only typechecks the test files (their
  // subjects are pulled in via imports).
  "compilerOptions": {
    "noEmit": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "paths": {
      "@shared/*": ["./src/shared/*"],
      "@main/*": ["./src/main/*"],
      "@renderer/*": ["./src/renderer/src/*"]
    },
    "strict": true,
    "noImplicitOverride": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node", "vite/client"]
  },
  "include": ["tests/**/*.ts"]
}
