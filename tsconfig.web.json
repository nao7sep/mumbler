{
  // Renderer environment: DOM, NO Node. `types: ["vite/client"]` deliberately
  // omits @types/node, so a renderer file that reaches for a Node global
  // (process, Buffer) or imports a `node:*` builtin fails to compile — it would be
  // broken in the sandboxed renderer at runtime. Preload is checked by
  // tsconfig.node.json, not here, precisely so its `electron` import can't drag
  // @types/node back into this program.
  "compilerOptions": {
    "composite": true,
    "outDir": "./out/tsbuild-web",
    "noEmit": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "paths": {
      "@shared/*": ["./src/shared/*"],
      "@renderer/*": ["./src/renderer/src/*"]
    },
    "strict": true,
    "noImplicitOverride": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"]
  },
  "include": [
    "src/renderer/**/*.ts",
    "src/renderer/**/*.tsx",
    "src/shared/**/*.ts",
    "src/shared/**/*.d.ts"
  ]
}
