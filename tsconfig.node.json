{
  // Main-process + preload environment: Node, NO DOM. Keeping the DOM lib out is
  // what statically catches a main/preload file reaching for a browser global
  // (document, window, localStorage) that would be undefined at runtime. Preload
  // sits here (not with the renderer) because it imports `electron`, whose types
  // transitively pull in @types/node — which would otherwise leak Node globals
  // back into the renderer program. The `File` it receives across the bridge is
  // available as one of @types/node's web globals.
  "compilerOptions": {
    "composite": true,
    "outDir": "./out/tsbuild-node",
    "noEmit": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@shared/*": ["./src/shared/*"],
      "@main/*": ["./src/main/*"]
    },
    "strict": true,
    "noImplicitOverride": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "lib": ["ES2022"],
    "types": ["node"]
  },
  "include": [
    "electron.vite.config.ts",
    "src/main/**/*.ts",
    "src/preload/**/*.ts",
    "src/shared/**/*.ts",
    "src/shared/**/*.d.ts"
  ]
}
